cd ~/skillfyAssignments/mlops-end2end

echo "===== MODULE 1: Git + DVC + Structure ====="
git status
find . -maxdepth 3 -type d | sort
find . -name "*.dvc"
dvc version
dvc status || true

echo "===== MODULE 2: Data Pipeline ====="
python3 -m compileall src
python3 -m src.data.ingest
python3 -m src.data.validate
python3 -m src.data.split
python3 -m src.data.preprocess
ls -lh data/processed
cat artifacts/validation_report.json

echo "===== MODULE 3: Training + Evaluation + MLflow ====="
python3 -m src.models.train
python3 -m src.models.evaluate
python3 -m src.pipeline.pipeline
ls -lh artifacts/models
ls -lh artifacts/metrics
ls -lh artifacts/reports
cat artifacts/metrics/metrics.json
ls -lh mlruns

echo "===== MODULE 4: Optuna ====="
python3 -m src.models.optuna_tuner
ls -lh artifacts/optuna
cat artifacts/optuna/best_params.json
cat artifacts/optuna/best_trial.json

echo "===== MODULE 5: MLflow Model Registry ====="
python3 - <<'EOF'
from mlflow.tracking import MlflowClient
client = MlflowClient()
for model in client.search_registered_models():
    print("MODEL:", model.name)
    for version in model.latest_versions:
        print("VERSION:", version.version, "STATUS:", version.status)
EOF

echo "===== MODULE 6: FastAPI ====="
python3 -m compileall src
uvicorn src.api.app:app --host 0.0.0.0 --port 8000 &
API_PID=$!
sleep 5
curl http://localhost:8000/health
curl http://localhost:8000/model-info
curl -X POST http://localhost:8000/predict \
  -H "Content-Type: application/json" \
  -d '{
    "fixed acidity": 7.4,
    "volatile acidity": 0.70,
    "citric acid": 0.00,
    "residual sugar": 1.9,
    "chlorides": 0.076,
    "free sulfur dioxide": 11.0,
    "total sulfur dioxide": 34.0,
    "density": 0.9978,
    "pH": 3.51,
    "sulphates": 0.56,
    "alcohol": 9.4
  }'
kill $API_PID

echo "===== MODULE 7: Docker ====="
docker build -t wine-quality-api:1.0 .
docker rm -f wine-quality-api 2>/dev/null || true
docker run -d --name wine-quality-api -p 8000:8000 \
  -v "$PWD/mlruns:/app/mlruns" \
  -v "$PWD/artifacts:/app/artifacts" \
  -v "$PWD/logs:/app/logs" \
  -v "$PWD/data:/app/data" \
  wine-quality-api:1.0
sleep 5
docker ps
curl http://localhost:8000/health
curl http://localhost:8000/model-info
docker rm -f wine-quality-api

echo "===== MODULE 8: Kubernetes ====="
kubectl apply --dry-run=client -f k8s/
kubectl apply -f k8s/
kubectl get deploy,svc,hpa,ingress
kubectl get pods -l app=wine-quality-api

echo "===== MODULE 9: Monitoring ====="
uvicorn src.api.app:app --host 0.0.0.0 --port 8000 &
API_PID=$!
sleep 5
curl http://localhost:8000/metrics | grep wine_quality
kill $API_PID

echo "===== MODULE 10: Airflow ====="
python3 -m py_compile airflow/dags/wine_quality_training_dag.py

echo "===== MODULE 11: GitHub Actions ====="
python3 -c "import yaml; yaml.safe_load(open('.github/workflows/ci.yml')); print('ci.yml OK')"
python3 -c "import yaml; yaml.safe_load(open('.github/workflows/docker.yml')); print('docker.yml OK')"

echo "===== MODULE 12: Tests ====="
python3 -m pytest tests -v

echo "===== MODULE 13: Documentation ====="
test -f README.md && echo "README.md exists"
grep -i "FastAPI" README.md
grep -i "MLflow" README.md
grep -i "Docker" README.md
grep -i "Kubernetes" README.md

echo "===== FINAL CHECK ====="
python3 -m compileall src
git status